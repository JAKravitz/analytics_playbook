# Optional shared persistence backend.
# When both are set at build time the playbook saves edits to a shared
# Supabase row so the whole commercial team sees the same content.
# Without these the app falls back to localStorage (per-browser only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Linear integration (Commercial requests page) ──────────────────────────
# Set these in Vercel → Project → Settings → Environment Variables (server-only).
# Do NOT prefix with VITE_ — they must never ship to the browser.
#
# LINEAR_API_KEY=<from Linear → Settings → API → Personal API keys>
# LINEAR_TEAM_ID=<team UUID — see README “Commercial requests → Linear”>
# LINEAR_PROJECT_ID=<optional default project UUID>
# LINEAR_LABEL_IDS=<optional comma-separated label UUIDs>
